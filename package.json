{
  "name": "vexis-dlmm-bot",
  "version": "0.1.0",
  "description": "CLI to view Meteora DLMM portfolio (open & closed positions)",
  "type": "module",
  "bin": {
    "vexis": "./dist/cli.js"
  },
  "scripts": {
    "postinstall": "node scripts/patch-cjs.cjs",
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "bot": "tsx src/telegram/bot.ts",
    "bot:start": "node dist/telegram/bot.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.31.1",
    "@effect/cli": "^0.76.0",
    "@effect/platform": "^0.97.0",
    "@effect/platform-node": "^0.108.0",
    "@effect/printer": "^0.50.0",
    "@effect/printer-ansi": "^0.50.0",
    "@meteora-ag/dlmm": "^1.9.10",
    "@meteora-ag/zap-sdk": "^1.3.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "commander": "^12.1.0",
    "effect": "^3.22.0",
    "grammy": "^1.44.0",
    "node-cron": "^4.4.1"
  },
  "devDependencies": {
    "@effect/vitest": "^0.30.0",
    "@types/bn.js": "^5.2.0",
    "@types/bs58": "^4.0.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.7"
  }
}
